# ─── App ──────────────────────────────────────────────────────────────────────
# A non-empty identifier for the app (used inside JWT claims)
VITE_APP_ID=lg-revenue

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# Not required for email/password auth — set to "disabled"
VITE_OAUTH_PORTAL_URL=disabled
OAUTH_SERVER_URL=disabled

# The openId value the first Super Admin will be registered under.
# Can be any unique string — e.g. use your email: "admin@your-org.ng"
OWNER_OPEN_ID=admin@your-org.ng

# ─── Database ─────────────────────────────────────────────────────────────────
# TiDB Cloud Serverless example:
#   mysql://root:<password>@<host>.tidbcloud.com:4000/lg_revenue?ssl={"rejectUnauthorized":true}
# Regular MySQL example:
#   mysql://user:password@localhost:3306/lg_revenue
DATABASE_URL=mysql://user:password@host:3306/lg_revenue

# ─── Email (optional) ─────────────────────────────────────────────────────────
# If left blank, email notifications are skipped silently
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=noreply@lg-revenue.gov.ng

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
